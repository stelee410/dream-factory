# =============================================================================
# DreamFactory — 复制为 .env 后按说明填写（勿提交到 git）
# 加载顺序：当前目录 .env 优先，其次 ~/.dreamfactory/.env
# =============================================================================

# -----------------------------------------------------------------------------
# linkyun.co — API 根地址（一般无需改）
# -----------------------------------------------------------------------------
LINKYUN_API_BASE=https://linkyun.co

# -----------------------------------------------------------------------------
# linkyun.co — 登录会话（可选）
#
# 推荐：在 CLI 里用账号密码登录并选择「保存到 .env」，由程序自动写入。
# 若手动填写：与登录 JSON 里 data.api_key（及 data.creator.api_key）一致。
# 正式 linkyun-agent 生成的形态为：sk- + 48 位十六进制（总长约 51）。
# 不要把 OpenRouter（sk-or-v1-…）、Anthropic（sk-ant-…）等其它密钥写进本项。
#
# LINKYUN_API_KEY=
# LINKYUN_WORKSPACE_CODE=
# LINKYUN_USERNAME=

# -----------------------------------------------------------------------------
# LLM — 文本生成与 Agent（OpenAI 兼容 `/v1/chat/completions`）
# 默认指向 OpenRouter；也可换任意兼容网关。
# LLM_API_KEY 未设置时，仍会回退读取 OPENROUTER_API_KEY（旧名）。
# -----------------------------------------------------------------------------
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4
LLM_API_KEY=
# OPENROUTER_API_KEY=


# -----------------------------------------------------------------------------
# 通义万相 Wan — 分镜图（可选；未配时可走其它图片能力）
# -----------------------------------------------------------------------------
WAN_API_KEY=

# -----------------------------------------------------------------------------
# Seedance — 图生视频（可选）
# -----------------------------------------------------------------------------
SEEDANCE_API_KEY=

# -----------------------------------------------------------------------------
# LibTV — AI 创作平台 Skill（可选）
# 从 https://www.liblib.tv 获取 access_key
# -----------------------------------------------------------------------------
LIBTV_ACCESS_KEY=
